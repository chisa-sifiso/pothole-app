{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (React + Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "AI Service (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000,
      "cwd": "ai-service"
    },
    {
      "name": "Backend (Spring Boot)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "C:\\maven\\apache-maven-3.9.6\\bin\\mvn.cmd", "spring-boot:run"],
      "port": 8081,
      "cwd": "backend",
      "env": {
        "JAVA_HOME": "C:\\Program Files\\Java\\jdk-17"
      }
    }
  ]
}
